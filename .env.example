PORT=3000
CLIENT_URL=http://localhost:3000

# Firebase Admin — path to service account JSON or use GOOGLE_APPLICATION_CREDENTIALS
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Optional: Google Places API for live place data
GEOAPIFY_API_KEY=

# Optional: Gemini for AI replies (falls back to rule-based responses if empty)
GEMINI_API_KEY=
